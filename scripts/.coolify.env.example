# =====================================================================
# Coolify deploy variables. Copy to scripts/.coolify.env and fill in.
# This file is gitignored.
# =====================================================================

# --- Coolify ---
COOLIFY_URL=http://localhost:8000
COOLIFY_TOKEN=
COOLIFY_SERVER_UUID=pgvwbkpz0oo531ef52j4ciuo
COOLIFY_PROJECT_NAME=marist-time-machine
COOLIFY_ENVIRONMENT_NAME=production

# --- Git source (must be a PUBLIC HTTPS repo) ---
GIT_REPO=https://github.com/<your-user>/<your-repo>.git
GIT_BRANCH=main

# --- Supabase resource (created via Coolify "One-Click" template) ---
# Get these from the Supabase resource page in Coolify after deploying it.
SUPABASE_URL=
SUPABASE_PUBLIC_URL=
ANON_KEY=
SERVICE_ROLE_KEY=
JWT_SECRET=
DATABASE_URL=

# --- App tunables ---
ML_MODEL_NAME=buffalo_l
ML_DET_THRESHOLD=0.7
ML_DET_SIZE=640
CLUSTER_MAX_DISTANCE=0.5
CLUSTER_MIN_FACES=3
CORS_ORIGINS=*

# --- Public domains (Coolify magic vars) ---
# Set these to the FQDNs you'll point at this Coolify instance.
# For local testing with sslip.io: <your-ip>.sslip.io subdomains.
SERVICE_FQDN_WEB=
SERVICE_FQDN_API=
