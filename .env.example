# ====================================================================
# Marist Time Machine — example environment
# Copy to .env and replace placeholder values.
# In production (Coolify), set these via Coolify's environment UI.
# ====================================================================

# -------- General --------
PROJECT_NAME=marist-time-machine
NODE_ENV=production

# -------- Postgres (used by Supabase + app) --------
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=db

# -------- Supabase: JWT --------
# Generate with: openssl rand -base64 64 (must be 32+ chars)
JWT_SECRET=replace-with-64-char-secret-at-least-32-chars-long
JWT_EXPIRY=3600

# Supabase API keys derived from JWT_SECRET.
# Generate at https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# or use: docker run --rm supabase/postgres-meta:latest sh -c 'echo $ANON_KEY'
ANON_KEY=replace-with-anon-jwt
SERVICE_ROLE_KEY=replace-with-service-role-jwt

# -------- Supabase: Studio dashboard --------
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=replace-with-strong-password

# -------- Supabase: URLs --------
# In production, set these to your public domain (Coolify will set the FQDN).
SITE_URL=http://localhost:5173
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# Internal URLs (container-to-container, do not change)
SUPABASE_URL=http://kong:8000
GOTRUE_URI_ALLOW_LIST=http://localhost:5173,http://localhost:3000

# -------- Storage --------
# Pick one of two modes:
#   - "file": stores photos in a local Docker volume (dev / single-VPS).
#   - "s3"  : stores photos in an S3-compatible bucket (prod, Hetzner Object Storage, etc.)
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800

# ---- S3 settings (only used when STORAGE_BACKEND=s3) ----
# Hetzner Object Storage example (Falkenstein):
#   S3_ENDPOINT=https://fsn1.your-objectstorage.com
#   S3_REGION=fsn1
# Other regions: nbg1 (Nuremberg), hel1 (Helsinki), ash (Ashburn)
S3_BUCKET=marist-time-machine
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
S3_PROTOCOL=https
S3_TENANT_ID=marist
# Set to "true" together with STORAGE_BACKEND=s3 to let imgproxy fetch from S3 directly.
IMGPROXY_USE_S3=false

# -------- App: API --------
API_PORT=8080
API_HOST=0.0.0.0

# -------- App: ML service --------
ML_PORT=8081
ML_HOST=0.0.0.0
ML_MODEL_NAME=buffalo_l
ML_DET_THRESHOLD=0.7
ML_DET_SIZE=640

# Inter-service URL (container-to-container)
ML_INTERNAL_URL=http://ml:8081

# -------- App: Web (Vite build-time vars) --------
# These are baked into the PWA bundle at build time.
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=replace-with-anon-jwt
VITE_API_URL=http://localhost:8080

# -------- Clustering parameters (DBSCAN-streaming, Immich-style) --------
CLUSTER_MAX_DISTANCE=0.5
CLUSTER_MIN_FACES=3
